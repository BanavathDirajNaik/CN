    {
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "ESTABLISHED": { "color": "green", "index": 0 } } },
                  { "type": "value", "options": { "TIME_WAIT": { "color": "yellow", "index": 1 } } },
                  { "type": "value", "options": { "CLOSE_WAIT": { "color": "orange", "index": 2 } } },
                  { "type": "value", "options": { "SYN_SENT": { "color": "blue", "index": 3 } } },
                  { "type": "value", "options": { "LISTEN": { "color": "purple", "index": 4 } } }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 61 },
      "id": 300,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "Application", "desc": false }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "sum by (app, pid, proto, local_ip, local_port, rem_ip, rem_port, state) (app_connections)",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true
            },
            "indexByName": {
              "app": 0,
              "pid": 1,
              "proto": 2,
              "local_ip": 3,
              "local_port": 4,
              "rem_ip": 5,
              "rem_port": 6,
              "state": 7
            },
            "renameByName": {
              "app": "Application",
              "pid": "PID",
              "proto": "Protocol",
              "local_ip": "Local IP",
              "local_port": "Local Port",
              "rem_ip": "Remote IP",
              "rem_port": "Remote Port",
              "state": "State"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{ "field": "Application" }]
          }
        }
      ],
      "title": "📋 Every Running App & Its Destinations",
      "type": "table"
    }
