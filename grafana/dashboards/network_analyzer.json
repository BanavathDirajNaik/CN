  "refresh": "15s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["network", "android", "real-time", "prometheus"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
        "definition": "label_values(app_rx_bytes, app)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "app",
        "options": [],
        "query": {
          "query": "label_values(app_rx_bytes, app)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "^(com\\.|org\\.|in\\.|android\\.|vendor\\.|[a-z][a-z_]+$).*",
        "sort": 1,
        "type": "query",
        "label": "Application"
      }
    ]
